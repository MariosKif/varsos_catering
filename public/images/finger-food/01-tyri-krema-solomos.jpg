<meta name="msapplication-TileImage" content="https://usercontent.one/wp/www.varsosparty.com/wp-content/uploads/2025/10/cropped-σημα-μικρο-2-270x270.jpg?media=1774651408" />
		<style id="wp-custom-css">
			/* ===== Varsos Catering Contact Form Styling ===== */
.wpcf7 form {
  max-width: 100%;
  background: #ffffff;
  border-radius: 12px;
  padding: 40px;
  box-shadow: 0 6px 25px rgba(0, 0, 0, 0.08);
  font-family: "Poppins", "Helvetica Neue", Arial, sans-serif;
}

.wpcf7 form label {
  display: block;
  font-weight: 600;
  font-size: 16px;
  color: #333;
  margin-bottom: 8px;
}

.wpcf7 input[type="text"],
.wpcf7 input[type="email"],
.wpcf7 textarea {
  width: 100%;
  padding: 14px 16px;
  border: 1.5px solid #ddd;
  border-radius: 8px;
  background-color: #fafafa;
  font-size: 15px;
  transition: all 0.3s ease;
  margin-bottom: 25px;
  box-sizing: border-box;
}

.wpcf7 input[type="text"]:focus,
.wpcf7 input[type="email"]:focus,
.wpcf7 textarea:focus {
  border-color: #ED0935;
  background-color: #fff;
  outline: none;
  box-shadow: 0 0 0 3px rgba(237, 9, 53, 0.15);
}

.wpcf7 textarea {
  min-height: 160px;
  resize: vertical;
}

/* === Full-Width Red Submit Button === */
.wpcf7 input[type="submit"] {
  display: block;
  width: 100%;
  background-color: #ED0935;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border: none;
  border-radius: 8px;
  padding: 16px;
  cursor: pointer;
  transition: all 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-top: 10px;
}

.wpcf7 input[type="submit"]:hover {
  background-color: #c6082d;
  transform: translateY(-1px);
  box-shadow: 0 4px 15px rgba(237, 9, 53, 0.3);
}

/* Placeholder Styling */
.wpcf7 input::placeholder,
.wpcf7 textarea::placeholder {
  color: #aaa;
}

/* Mobile Responsive */
@media (max-width: 768px) {
  .wpcf7 form {
    padding: 25px;
  }
  .wpcf7 input[type="submit"] {
    font-size: 15px;
  }
}
		</style>
		</head>
