---
import UploadControl from './UploadControl.astro';
import ColorSelector from './ColorSelector.astro';

/**
 * HeroCakeCustomizer
 * ------------------
 * Full-width hero section containing:
 *  1. Headline / sub-headline
 *  2. The cake preview with an upload overlay (clipped to the white area)
 *  3. Color selector for frosting
 *  4. Upload controls
 *  5. CTA button
 *
 * ## How the overlay works
 * The cake image sits inside a wrapper with `position: relative`.
 * A sibling `<div>` is absolutely positioned over it with a CSS
 * `clip-path: polygon(…)` whose four vertices match the white edible-print
 * zone on the photograph.  The user's uploaded image is rendered inside
 * that clipped area with `object-fit: cover`, giving the illusion that the
 * image is printed onto the cake surface.  A subtle multiply blend mode
 * and slight opacity reduction make it look "printed" rather than pasted.
 *
 * ## How the frosting recolor works
 * CSS `filter: hue-rotate(…) saturate(…)` is applied **only** to the
 * `<img>` of the cake (not the overlay).  Because the cake body and
 * background are near-white / grey (low saturation), the rotation barely
 * affects them.  The highly-saturated pink frosting shifts convincingly
 * to the target hue.
 */
---

<section
  id="hero"
  class="relative overflow-hidden bg-gradient-to-b from-brand-50 via-white to-white"
>
  {/* decorative blobs */}
  <div class="pointer-events-none absolute -top-32 -left-32 h-96 w-96 rounded-full bg-brand-100/60 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-40 -right-40 h-[30rem] w-[30rem] rounded-full bg-brand-100/40 blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-6xl px-4 pt-28 pb-20 sm:px-6 lg:px-8 lg:pt-36 lg:pb-28">
    {/* ─── Text ─── */}
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600" data-gsap-fade>
        Varsos Catering
      </p>
      <h1
        class="mt-3 font-heading text-4xl font-bold leading-tight tracking-tight text-gray-900 sm:text-5xl lg:text-6xl"
        data-gsap-fade
      >
        Σχεδίασε τη δική σου τούρτα
      </h1>
      <p class="mt-4 text-base leading-relaxed text-gray-500 sm:text-lg lg:text-xl" data-gsap-fade>
        Ανέβασε μια εικόνα, διάλεξε χρώμα γλάσου και δες αμέσως πώς θα φαίνεται
        η τούρτα σου — σε πραγματικό χρόνο.
      </p>
    </div>

    {/* ─── Cake Preview Card ─── */}
    <div
      class="relative mx-auto mt-12 max-w-2xl rounded-3xl bg-white p-3 shadow-2xl shadow-gray-900/8 ring-1 ring-gray-900/5 sm:p-5 lg:mt-16"
      data-gsap-fade
    >
      {/* cake image wrapper */}
      <div id="cake-wrapper" class="relative mx-auto select-none overflow-hidden rounded-2xl">
        {/* the actual cake photo — filter is updated via JS */}
        <img
          id="cake-image"
          src="/images/cake-base.jpg"
          alt="Βάση τούρτας με λευκή περιοχή εκτύπωσης και ροζ γλάσο"
          class="block w-full h-auto transition-[filter] duration-300 ease-in-out"
          width="1536"
          height="1024"
          draggable="false"
        />

        {/* ── Upload overlay — positioned exactly over the white edible-print zone ──
             The container is placed at the bounding box of the white area,
             then clip-path trims it to the exact trapezoid shape.
             User image uses object-fit:cover so it fills the entire zone. ── */}
        <div
          id="overlay-container"
          class="pointer-events-none absolute overflow-hidden"
          style="
            left: 15.36%;
            top: 17.19%;
            width: 71.42%;
            height: 45.02%;
            clip-path: polygon(4% 1.3%, 94.4% 0%, 100% 99.6%, 0% 98.9%);
          "
          aria-hidden="true"
        >
          {/* user image — contained within the white print zone */}
          <img
            id="image-overlay"
            src=""
            alt=""
            class="hidden absolute object-cover opacity-[0.92]"
            style="inset: 0; width: 100%; height: 100%; mix-blend-mode: multiply;"
            draggable="false"
          />

          {/* placeholder prompt — visible until user uploads */}
          <div
            id="preview-placeholder"
            class="absolute flex flex-col items-center justify-center gap-2 text-center"
            style="inset: 0;"
          >
            <svg class="h-10 w-10 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21zM9.75 9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
            <span class="text-xs font-medium text-gray-400 sm:text-sm">
              Η εικόνα σου εδώ
            </span>
          </div>
        </div>

        {/* drop zone highlight */}
        <div
          id="drop-highlight"
          class="pointer-events-none absolute inset-0 hidden rounded-2xl border-2 border-dashed border-brand-500 bg-brand-500/10 transition-opacity"
          aria-hidden="true"
        ></div>
      </div>

      {/* ── Controls row ── */}
      <div class="mt-5 flex flex-col items-center gap-5 sm:mt-6">
        <ColorSelector />
        <UploadControl />
      </div>
    </div>

    {/* ─── CTA ─── */}
    <div class="mt-10 text-center lg:mt-14" data-gsap-fade>
      <a
        href="/epikoinonia"
        class="inline-flex items-center gap-2 rounded-full bg-gray-900 px-8 py-4 text-sm font-semibold text-white shadow-xl shadow-gray-900/20 transition-all hover:bg-gray-800 hover:shadow-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-900 focus-visible:ring-offset-2 active:scale-[0.97]"
      >
        Παράγγειλε τη τούρτα σου
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>

{/* ═══════════════════════════════════════════════════════════════
    Client-side interactivity — runs only in the browser.
    Handles: upload / remove / change image, frosting color swatches,
    drag-and-drop, GSAP entrance animations, file validation.
═══════════════════════════════════════════════════════════════ */}
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  /* ── Constants ─────────────────────────────────────────── */
  const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5 MB
  const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/webp'];

  /* ── DOM refs ────────────────────────────────────────────── */
  const cakeImage       = document.getElementById('cake-image')       as HTMLImageElement;
  const overlayImg      = document.getElementById('image-overlay')    as HTMLImageElement;
  const placeholder     = document.getElementById('preview-placeholder')!;
  const uploadInput     = document.getElementById('cake-upload-input') as HTMLInputElement;
  const uploadBtn       = document.getElementById('upload-btn')!;
  const changeBtn       = document.getElementById('change-btn')!;
  const removeBtn       = document.getElementById('remove-btn')!;
  const uploadActions   = document.getElementById('upload-actions')!;
  const uploadError     = document.getElementById('upload-error')!;
  const cakeWrapper     = document.getElementById('cake-wrapper')!;
  const dropHighlight   = document.getElementById('drop-highlight')!;
  const colorBtns       = document.querySelectorAll<HTMLButtonElement>('[data-color-btn]');

  /* ── File validation ─────────────────────────────────────── */
  function validateFile(file: File): string | null {
    if (!ALLOWED_TYPES.includes(file.type)) {
      return 'Μόνο αρχεία JPG, PNG ή WebP.';
    }
    if (file.size > MAX_FILE_SIZE) {
      return 'Το αρχείο υπερβαίνει τα 5 MB.';
    }
    return null;
  }

  function showError(msg: string) {
    uploadError.textContent = msg;
    uploadError.classList.remove('hidden');
    setTimeout(() => uploadError.classList.add('hidden'), 4000);
  }

  /* ── Image processing (rotate portrait → landscape, crop-to-fill zone) ── */
  async function processImage(file: File): Promise<string> {
    const bitmap = await createImageBitmap(file);
    const isPortrait = bitmap.height > bitmap.width;

    // Effective dimensions after potential rotation
    const srcW = isPortrait ? bitmap.height : bitmap.width;
    const srcH = isPortrait ? bitmap.width  : bitmap.height;

    const TARGET_W = 1100;
    const TARGET_H = 460;

    // Cover scale: image fully covers the target, excess is cropped
    const scale = Math.max(TARGET_W / srcW, TARGET_H / srcH);
    const scaledW = Math.round(srcW * scale);
    const scaledH = Math.round(srcH * scale);

    // Center-crop offsets (negative values crop the excess)
    const offsetX = Math.round((TARGET_W - scaledW) / 2);
    const offsetY = Math.round((TARGET_H - scaledH) / 2);

    const canvas = document.createElement('canvas');
    canvas.width = TARGET_W;
    canvas.height = TARGET_H;
    const ctx = canvas.getContext('2d')!;

    if (isPortrait) {
      // Rotate 90° CW: swap axes, then draw into rotated space
      ctx.translate(TARGET_W, 0);
      ctx.rotate(Math.PI / 2);
      // In rotated space the canvas is TARGET_H × TARGET_W
      const rScale = Math.max(TARGET_H / bitmap.width, TARGET_W / bitmap.height);
      const rW = Math.round(bitmap.width * rScale);
      const rH = Math.round(bitmap.height * rScale);
      const rOffX = Math.round((TARGET_H - rW) / 2);
      const rOffY = Math.round((TARGET_W - rH) / 2);
      ctx.drawImage(bitmap, rOffX, rOffY, rW, rH);
    } else {
      ctx.drawImage(bitmap, offsetX, offsetY, scaledW, scaledH);
    }

    bitmap.close();

    return new Promise((resolve) => {
      canvas.toBlob((blob) => {
        resolve(URL.createObjectURL(blob!));
      }, file.type === 'image/png' ? 'image/png' : 'image/jpeg', 0.92);
    });
  }

  /* ── Upload handling ────────────────────────────────────── */
  let objectUrl: string | null = null;

  async function showImage(file: File) {
    const error = validateFile(file);
    if (error) { showError(error); return; }

    if (objectUrl) URL.revokeObjectURL(objectUrl);

    objectUrl = await processImage(file);
    overlayImg.src = objectUrl;
    overlayImg.alt = 'Προεπισκόπηση σχεδίου τούρτας';
    overlayImg.classList.remove('hidden');
    gsap.fromTo(overlayImg, { opacity: 0 }, { opacity: 0.92, duration: 0.4, ease: 'power2.out' });

    placeholder.classList.add('hidden');
    uploadBtn.classList.add('hidden');
    uploadActions.classList.remove('hidden');
    uploadActions.classList.add('flex');
    uploadError.classList.add('hidden');

    changeBtn.focus();
  }

  function clearImage() {
    if (objectUrl) { URL.revokeObjectURL(objectUrl); objectUrl = null; }

    gsap.to(overlayImg, {
      opacity: 0,
      duration: 0.3,
      ease: 'power2.in',
      onComplete: () => {
        overlayImg.src = '';
        overlayImg.alt = '';
        overlayImg.classList.add('hidden');
      },
    });

    placeholder.classList.remove('hidden');
    gsap.fromTo(placeholder, { opacity: 0 }, { opacity: 1, duration: 0.3, delay: 0.2 });

    uploadBtn.classList.remove('hidden');
    uploadActions.classList.add('hidden');
    uploadActions.classList.remove('flex');
    uploadInput.value = '';
    uploadError.classList.add('hidden');
  }

  uploadInput.addEventListener('change', () => {
    const file = uploadInput.files?.[0];
    if (file) showImage(file);
  });

  uploadBtn.addEventListener('click', () => uploadInput.click());
  changeBtn.addEventListener('click', () => { uploadInput.value = ''; uploadInput.click(); });
  removeBtn.addEventListener('click', clearImage);

  /* ── Drag & drop ────────────────────────────────────────── */
  function preventDefaults(e: Event) { e.preventDefault(); e.stopPropagation(); }

  (['dragenter', 'dragover'] as const).forEach(evt =>
    cakeWrapper.addEventListener(evt, (e) => { preventDefaults(e); dropHighlight.classList.remove('hidden'); })
  );
  (['dragleave', 'drop'] as const).forEach(evt =>
    cakeWrapper.addEventListener(evt, (e) => { preventDefaults(e); dropHighlight.classList.add('hidden'); })
  );
  cakeWrapper.addEventListener('drop', (e) => {
    const file = (e as DragEvent).dataTransfer?.files[0];
    if (file) showImage(file);
  });

  /* ── Frosting color ─────────────────────────────────────── */
  colorBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'hue-rotate(0deg)';
      cakeImage.style.filter = filter;

      // update ARIA + visual states
      colorBtns.forEach((b) => {
        const isActive = b === btn;
        b.setAttribute('aria-checked', String(isActive));
        b.classList.toggle('border-gray-900', isActive);
        b.classList.toggle('ring-2', isActive);
        b.classList.toggle('ring-gray-900', isActive);
        b.classList.toggle('ring-offset-2', isActive);
        b.classList.toggle('scale-110', isActive);
        b.classList.toggle('border-white', !isActive);
        b.classList.toggle('shadow-md', !isActive);
        const icon = b.querySelector('.check-icon') as HTMLElement | null;
        if (icon) {
          icon.classList.toggle('opacity-100', isActive);
          icon.classList.toggle('opacity-0', !isActive);
        }
      });
    });
  });

  /* ── GSAP entrance animations ───────────────────────────── */
  gsap.defaults({ ease: 'power3.out' });

  // Stagger-in for hero text
  gsap.from('[data-gsap-fade]', {
    y: 30,
    opacity: 0,
    duration: 0.9,
    stagger: 0.15,
    delay: 0.2,
  });
</script>
