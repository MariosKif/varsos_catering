---
/**
 * ColorSelector — frosting color swatch picker.
 *
 * Each swatch stores a CSS `filter` value applied to the cake <img>.
 * Because the original frosting is pink (~340° hue), a CSS hue-rotate
 * shifts only the saturated pixels (frosting) while whites and greys
 * stay virtually unchanged.
 */

interface FrostingColor {
  name: string;
  swatch: string;           // visual swatch color
  filter: string;           // CSS filter applied to the cake image
}

const colors: FrostingColor[] = [
  { name: 'Ροζ',        swatch: '#E85D8A', filter: 'hue-rotate(0deg)' },
  { name: 'Κόκκινο',    swatch: '#DC2626', filter: 'hue-rotate(345deg) saturate(1.4)' },
  { name: 'Κοραλί',     swatch: '#EA580C', filter: 'hue-rotate(18deg) saturate(1.2)' },
  { name: 'Χρυσό',      swatch: '#CA8A04', filter: 'hue-rotate(55deg) saturate(1.05) brightness(1.05)' },
  { name: 'Πράσινο',    swatch: '#16A34A', filter: 'hue-rotate(140deg) saturate(1.15)' },
  { name: 'Τιρκουάζ',   swatch: '#0891B2', filter: 'hue-rotate(195deg) saturate(1.2)' },
  { name: 'Μπλε',       swatch: '#2563EB', filter: 'hue-rotate(235deg) saturate(1.3)' },
  { name: 'Μωβ',        swatch: '#9333EA', filter: 'hue-rotate(300deg) saturate(1.15)' },
];
---

<fieldset class="flex flex-col items-center gap-3" role="radiogroup" aria-label="Επιλογή χρώματος γλάσου">
  <legend class="text-sm font-medium text-gray-600 mb-1">Χρώμα γλάσου</legend>

  <div class="flex flex-wrap justify-center gap-2.5">
    {colors.map((c, i) => (
      <button
        type="button"
        role="radio"
        aria-checked={i === 0 ? 'true' : 'false'}
        aria-label={c.name}
        data-color-btn
        data-filter={c.filter}
        class:list={[
          'color-swatch group relative h-9 w-9 rounded-full border-2 transition-all duration-200',
          'hover:scale-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2',
          i === 0
            ? 'border-gray-900 ring-2 ring-gray-900 ring-offset-2 scale-110'
            : 'border-white shadow-md hover:border-gray-300',
        ]}
        style={`background-color: ${c.swatch};`}
        title={c.name}
      >
        {/* check icon for active state */}
        <svg
          class:list={[
            'check-icon absolute inset-0 m-auto h-4 w-4 text-white drop-shadow-sm transition-opacity',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
            clip-rule="evenodd"
          />
        </svg>
      </button>
    ))}
  </div>
</fieldset>
