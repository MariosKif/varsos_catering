---
/**
 * UploadControl — file upload button + remove / change controls.
 *
 * The hidden <input type="file"> is triggered by clicking the visible
 * button. After an image is selected the "remove" and "change" actions
 * become visible.
 */
---

<div class="flex flex-col items-center gap-3" data-upload-root>
  {/* hidden native input */}
  <input
    type="file"
    id="cake-upload-input"
    accept="image/jpeg,image/png,image/webp"
    class="sr-only"
    aria-label="Ανέβασμα εικόνας για την τούρτα"
  />
  {/* validation error message */}
  <p id="upload-error" class="hidden text-xs font-medium text-red-600" role="alert" aria-live="polite"></p>

  {/* primary upload button — shown when no image is selected */}
  <button
    type="button"
    id="upload-btn"
    class="inline-flex items-center gap-2 rounded-full bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-600/25 transition-all hover:bg-brand-700 hover:shadow-xl hover:shadow-brand-700/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2 active:scale-[0.97]"
  >
    <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path d="M9.25 13.25a.75.75 0 001.5 0V4.636l2.955 3.129a.75.75 0 001.09-1.03l-4.25-4.5a.75.75 0 00-1.09 0l-4.25 4.5a.75.75 0 101.09 1.03L9.25 4.636v8.614z" />
      <path d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z" />
    </svg>
    Ανέβασε το σχέδιό σου
  </button>

  {/* secondary actions — shown after upload */}
  <div id="upload-actions" class="hidden flex items-center gap-3">
    <button
      type="button"
      id="change-btn"
      class="inline-flex items-center gap-1.5 rounded-full border border-gray-300 bg-white px-4 py-2 text-xs font-medium text-gray-700 shadow-sm transition-all hover:bg-gray-50 hover:border-gray-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
    >
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M15.312 11.424a5.5 5.5 0 01-9.201 2.466l-.312-.311h2.433a.75.75 0 000-1.5H4.598a.75.75 0 00-.75.75v3.634a.75.75 0 001.5 0v-2.033l.312.31a7 7 0 0011.712-3.138.75.75 0 00-1.449-.39 5.5 5.5 0 01-.611 1.212zM4.688 8.576a5.5 5.5 0 019.201-2.466l.312.311H11.77a.75.75 0 000 1.5h3.634a.75.75 0 00.75-.75V3.537a.75.75 0 00-1.5 0v2.033l-.312-.31A7 7 0 002.63 8.388a.75.75 0 001.449.39c.16-.434.374-.843.61-1.202z" />
      </svg>
      Αλλαγή
    </button>
    <button
      type="button"
      id="remove-btn"
      class="inline-flex items-center gap-1.5 rounded-full border border-red-200 bg-white px-4 py-2 text-xs font-medium text-red-600 shadow-sm transition-all hover:bg-red-50 hover:border-red-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-offset-2"
    >
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.52.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 01.78.72l.5 6.5a.75.75 0 01-1.499.115l-.5-6.5a.75.75 0 01.72-.78zm3.62.72a.75.75 0 00-1.5-.115l-.5 6.5a.75.75 0 001.5.115l.5-6.5z" clip-rule="evenodd" />
      </svg>
      Αφαίρεση
    </button>
  </div>
</div>
