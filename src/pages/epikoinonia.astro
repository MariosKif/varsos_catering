---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Επικοινωνία — Varsos Catering"
  description="Επικοινωνήστε με τη Varsos Catering για catering εκδηλώσεων, προσφορές και παραγγελίες στην Αθήνα. Τηλέφωνο, email και φόρμα επικοινωνίας."
>
  <Header currentPath="/epikoinonia" />

  {/* ─── Hero Banner ─── */}
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-50 via-white to-white pt-28 pb-16 px-4 sm:px-6 lg:px-8 lg:pt-36 lg:pb-20">
    <div class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full bg-brand-100/60 blur-3xl" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600" data-gsap-fade>Επικοινωνία</p>
      <h1 class="mt-3 font-heading text-4xl font-bold leading-tight tracking-tight text-gray-900 sm:text-5xl" data-gsap-fade>
        Ας μιλήσουμε
      </h1>
      <p class="mt-4 text-base leading-relaxed text-gray-500 sm:text-lg" data-gsap-fade>
        Έτοιμοι να σχεδιάσουμε μαζί την επόμενη εκδήλωσή σας. Στείλτε μας μήνυμα και θα επικοινωνήσουμε σύντομα.
      </p>
    </div>
  </section>

  {/* ─── Contact Info Cards ─── */}
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {/* Phone */}
        <div class="group rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-900/5 text-center transition-all hover:shadow-lg hover:-translate-y-1">
          <div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700 transition-colors group-hover:bg-brand-600 group-hover:text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Τηλέφωνο</h3>
          <p class="mt-2 text-sm text-gray-500">Δευτέρα – Σάββατο, 9:00 – 18:00</p>
          <a href="tel:+302101234567" class="mt-3 inline-block text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors">
            210 123 4567
          </a>
        </div>

        {/* Email */}
        <div class="group rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-900/5 text-center transition-all hover:shadow-lg hover:-translate-y-1">
          <div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700 transition-colors group-hover:bg-brand-600 group-hover:text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Email</h3>
          <p class="mt-2 text-sm text-gray-500">Απαντάμε εντός 24 ωρών</p>
          <a href="mailto:info@varsoscatering.gr" class="mt-3 inline-block text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors">
            info@varsoscatering.gr
          </a>
        </div>

        {/* Address */}
        <div class="group rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-900/5 text-center transition-all hover:shadow-lg hover:-translate-y-1 sm:col-span-2 lg:col-span-1">
          <div class="mx-auto mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700 transition-colors group-hover:bg-brand-600 group-hover:text-white">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900">Διεύθυνση</h3>
          <p class="mt-2 text-sm text-gray-500">Αθήνα, Αττική</p>
          <p class="mt-1 text-sm font-semibold text-brand-600">Κατόπιν ραντεβού</p>
        </div>
      </div>
    </div>
  </section>

  {/* ─── Contact Form ─── */}
  <section class="bg-gray-50 py-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <div class="text-center">
        <h2 class="font-heading text-2xl font-bold text-gray-900 sm:text-3xl">Στείλτε μας μήνυμα</h2>
        <p class="mt-3 text-gray-500">Συμπληρώστε τη φόρμα και θα επικοινωνήσουμε μαζί σας το συντομότερο.</p>
      </div>

      <form id="contact-form" class="mt-10 space-y-6">
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700">Ονοματεπώνυμο</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-1.5 block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 shadow-sm transition-colors focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
              placeholder="π.χ. Μαρία Παπαδοπούλου"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700">Τηλέφωνο</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="mt-1.5 block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 shadow-sm transition-colors focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
              placeholder="π.χ. 69x xxx xxxx"
            />
          </div>
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="mt-1.5 block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 shadow-sm transition-colors focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
            placeholder="π.χ. maria@example.com"
          />
        </div>

        <div>
          <label for="event-type" class="block text-sm font-medium text-gray-700">Τύπος εκδήλωσης</label>
          <select
            id="event-type"
            name="event-type"
            class="mt-1.5 block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 shadow-sm transition-colors focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
          >
            <option value="">Επιλέξτε...</option>
            <option value="wedding">Γάμος</option>
            <option value="baptism">Βάπτιση</option>
            <option value="corporate">Εταιρικό Event</option>
            <option value="party">Πάρτι / Δεξίωση</option>
            <option value="other">Άλλο</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700">Μήνυμα</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="mt-1.5 block w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 shadow-sm transition-colors focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20 resize-y"
            placeholder="Πείτε μας για την εκδήλωσή σας — ημερομηνία, αριθμός ατόμων, προτιμήσεις μενού..."
          ></textarea>
        </div>

        <div class="text-center">
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-full bg-brand-600 px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-brand-600/25 transition-all hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2 active:scale-[0.97]"
          >
            Αποστολή
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M3.105 2.289a.75.75 0 00-.826.95l1.414 4.925A1.5 1.5 0 005.135 9.25h6.115a.75.75 0 010 1.5H5.135a1.5 1.5 0 00-1.442 1.086l-1.414 4.926a.75.75 0 00.826.95 28.896 28.896 0 0015.293-7.154.75.75 0 000-1.115A28.897 28.897 0 003.105 2.289z" />
            </svg>
          </button>
        </div>

        {/* Success message (hidden by default) */}
        <div id="form-success" class="hidden rounded-xl bg-green-50 border border-green-200 p-4 text-center">
          <p class="text-sm font-medium text-green-800">Το μήνυμά σας στάλθηκε επιτυχώς! Θα επικοινωνήσουμε σύντομα.</p>
        </div>
      </form>
    </div>
  </section>

  {/* ─── Quick CTA ─── */}
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-xl text-center">
      <h2 class="font-heading text-2xl font-bold text-gray-900 sm:text-3xl">Προτιμάτε τηλεφωνική επικοινωνία;</h2>
      <p class="mt-4 text-gray-500">Καλέστε μας απευθείας για άμεση εξυπηρέτηση.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="tel:+302101234567"
          class="inline-flex items-center gap-2 rounded-full bg-brand-600 px-7 py-3.5 text-sm font-semibold text-white shadow-lg shadow-brand-600/25 transition-all hover:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          210 123 4567
        </a>
        <a
          href="mailto:info@varsoscatering.gr"
          class="inline-flex items-center gap-2 rounded-full border border-gray-300 bg-white px-7 py-3.5 text-sm font-semibold text-gray-700 shadow-sm transition-all hover:bg-gray-50 hover:border-gray-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-600 focus-visible:ring-offset-2"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          Στείλτε email
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  import { gsap } from 'gsap';
  gsap.defaults({ ease: 'power3.out' });
  gsap.from('[data-gsap-fade]', {
    y: 30,
    opacity: 0,
    duration: 0.9,
    stagger: 0.15,
    delay: 0.2,
  });

  // Basic form handling (show success message, no backend)
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      success.classList.remove('hidden');
      gsap.fromTo(success, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.5 });
      form.reset();
    });
  }
</script>
