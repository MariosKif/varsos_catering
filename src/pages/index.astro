---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroCakeCustomizer from '../components/HeroCakeCustomizer.astro';
import AlternatingSection from '../components/AlternatingSection.astro';
---

<Layout>
  {/* ─── Navigation ─── */}
  <Header currentPath="/" />

  {/* ─── Hero / Cake Customizer ─── */}
  <HeroCakeCustomizer />

  {/* ─── Alternating Content Sections ─── */}
  <AlternatingSection
    title="Finger Food"
    text="Αναζητάτε τις πιο νόστιμες ιδέες για finger food; Από το 1987 δημιουργούμε χειροποίητα ορεκτικά με ποιοτικά υλικά χωρίς συντηρητικά. Mini burgers, παραδοσιακές μπόμπες και αλμυρά ορεκτικά σε ποικιλία γεύσεων."
    imageSide="left"
    iconPath="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265z"
  />

  <AlternatingSection
    title="Πακέτα Προσφορών"
    text="Οικονομικά πακέτα catering στην Αθήνα με finger food, έτοιμα μενού και επιλογές ανά άτομο. Ιδανικά για το σπίτι ή σε χώρο εκδήλωσης, με φρέσκα υλικά και ποικιλία για μικρούς και μεγάλους."
    imageSide="right"
    bgClass="bg-gray-50"
    iconPath="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"
  />

  <AlternatingSection
    title="Προϊόντα & Τιμές"
    text="Ανακαλύψτε τον πλήρη τιμοκατάλογό μας με brioche sandwiches, καναπεδάκια, μεζεδάκια, σαλάτες, ταψάκια, χειροποίητες πίτες και τούρτες. Ποιοτικό catering από το 1987."
    imageSide="left"
    iconPath="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
  />

  {/* ─── Services ─── */}
  <section id="services" class="bg-gray-50 py-24 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-600">Υπηρεσίες</p>
        <h2 class="mt-2 font-heading text-3xl font-bold text-gray-900 sm:text-4xl">
          Για κάθε ξεχωριστή στιγμή
        </h2>
        <p class="mt-3 mx-auto max-w-xl text-gray-500">
          Από γάμους μέχρι εταιρικά events, δημιουργούμε γευστικές εμπειρίες που μένουν αξέχαστες.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: 'Γάμοι',
            desc: 'Ειδικά σχεδιασμένα μενού και τούρτες για την πιο σημαντική μέρα σας.',
            icon: 'M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z',
          },
          {
            title: 'Εταιρικά Events',
            desc: 'Επαγγελματικό catering για συνέδρια, δεξιώσεις και meetings.',
            icon: 'M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0',
          },
          {
            title: 'Ιδιωτικές Δεξιώσεις',
            desc: 'Από intimate dinner parties μέχρι μεγάλες γιορτές.',
            icon: 'M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z',
          },
        ].map(({ title, desc, icon }) => (
          <div class="group rounded-2xl bg-white p-8 shadow-sm ring-1 ring-gray-900/5 transition-all hover:shadow-lg hover:-translate-y-1">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700 transition-colors group-hover:bg-brand-600 group-hover:text-white">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-500">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─── Footer ─── */}
  <Footer />
</Layout>
